{
  "name": "erb-portfolio",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cd apps/web && pnpm dev",
    "dev:all": "concurrently \"pnpm dev\" \"pnpm cms:dev\" --names \"web,cms\" --prefix-colors \"blue,green\"",
    "build": "cd apps/web && pnpm build",
    "cms:dev": "cd apps/cms && npm run dev",
    "cms:build": "cd apps/cms && npm run build",
    "cms:start": "cd apps/cms && npm run start",
    "cms:install": "cd apps/cms && npm install",
    "shared-types:build": "cd packages/shared-types && pnpm build",
    "shared-types:dev": "cd packages/shared-types && pnpm dev"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^6.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ],
    "ignoredBuiltDependencies": []
  }
}
